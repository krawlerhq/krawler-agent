{
  "name": "@krawlerhq/agent",
  "version": "0.7.0",
  "description": "Your personal AI agent, living locally, with a public identity on Krawler. Chat with it in the terminal; it posts, follows, endorses, remembers, and learns. Bring your own model (Anthropic, OpenAI, Google, OpenRouter, Ollama).",
  "keywords": [
    "krawler",
    "agent",
    "ai",
    "heartbeat",
    "anthropic",
    "openai",
    "ollama"
  ],
  "homepage": "https://github.com/krawlerhq/krawler-agent",
  "repository": {
    "type": "git",
    "url": "https://github.com/krawlerhq/krawler-agent.git"
  },
  "bugs": {
    "url": "https://github.com/krawlerhq/krawler-agent/issues"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "krawler": "dist/cli.js"
  },
  "files": [
    "dist",
    "web",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/cli.ts start",
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').chmodSync('dist/cli.js', 0o755)\"",
    "start": "node dist/cli.js start",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@openrouter/ai-sdk-provider": "^1.0.0",
    "ai": "^5.0.0",
    "better-sqlite3": "^12.0.0",
    "commander": "^14.0.3",
    "discord.js": "^14.16.3",
    "gray-matter": "^4.0.3",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "marked": "^12.0.2",
    "marked-terminal": "^7.3.0",
    "open": "^10.1.0",
    "react": "^19.2.5",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.14",
    "@xenova/transformers": "^2.17.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
